{
  "name": "bringppttest",
  "version": "4.1.11",
  "description": "薄云咨询 PPT 生成 Skill — 基于 pptxgenjs 的 BRING 品牌模板系统（v4.1.11：91 模板 + upload_file_to_drive 调用契约 + 通过外部 upload-file-to-drive 插件上传 Drive，由 BRINGPPT_UPLOAD_COMMAND 指向独立 adapter）",
  "main": "bring-core.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "validate": "node validate-slides.js",
    "validate:all": "node validate-slides.js --content --visual --stats",
    "learning": "node learning-context.js",
    "pipeline": "node ppt-pipeline.js",
    "checkup": "node weekly-checkup.js",
    "checkup:dry": "node weekly-checkup.js --dry-run",
    "pdf": "python3 scripts/soffice.py --headless --convert-to pdf",
    "outline": "node scripts/outline-to-storyboard.js",
    "recommend": "node scripts/recommend-layout.js",
    "regen": "node scripts/regenerate-slide.js",
    "preview": "node scripts/live-preview.js",
    "catalog": "node scripts/build-catalog.js",
    "new:template": "node scripts/new-template.js",
    "lint": "node scripts/lint.js",
    "lint:fonts": "node scripts/lint-fonts.js",
    "lint:zorder": "node scripts/scan-zorder.js",
    "learning:report": "node scripts/learning-report.js",
    "promote:traps": "node scripts/promote-traps.js",
    "weights:reset": "node scripts/reset-weights.js",
    "weights:reset:dry": "node scripts/reset-weights.js --dry-run",
    "backfill:failures": "node scripts/backfill-failure-modes.js",
    "learning:triage": "node scripts/learning-report.js --triage",
    "doctor": "node scripts/doctor.js",
    "doctor:visual": "node scripts/doctor.js --visual",
    "clean": "node scripts/clean.js",
    "cleanup": "bash scripts/cleanup-workspace.sh"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pptxgenjs": "4.0.1"
  }
}
